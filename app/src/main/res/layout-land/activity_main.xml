<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:background="@color/bg_dark"
    android:padding="16dp">

    <!-- Columna izquierda: header + controles Shizuku -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginEnd="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_gradient_header"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="⚡ GAME OPTIMIZER"
                android:textColor="@color/bg_dark"
                android:textSize="18sp"
                android:textStyle="bold"
                android:letterSpacing="0.05" />

            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Comprobando estado de Shizuku..."
                android:textColor="@color/bg_dark"
                android:textSize="12sp"
                android:alpha="0.85" />
        </LinearLayout>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <LinearLayout
                android:id="@+id/cardSetup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card"
                android:padding="14dp"
                android:animateLayoutChanges="true">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnInstallShizuku"
                    style="@style/Theme.GameOptimizer.Button"
                    android:layout_width="match_parent"
                    android:layout_height="46dp"
                    android:textSize="12sp"
                    android:text="Instalar Shizuku"
                    android:layout_marginBottom="8dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnOpenDevOptions"
                    style="@style/Theme.GameOptimizer.Button.Outline"
                    android:layout_width="match_parent"
                    android:layout_height="46dp"
                    android:textSize="12sp"
                    android:text="Opciones de Desarrollador"
                    android:layout_marginBottom="8dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnGrantPermission"
                    style="@style/Theme.GameOptimizer.Button.Outline"
                    android:layout_width="match_parent"
                    android:layout_height="46dp"
                    android:textSize="12sp"
                    android:text="Otorgar permiso Shizuku"
                    android:layout_marginBottom="8dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnGrantOverlay"
                    style="@style/Theme.GameOptimizer.Button.Outline"
                    android:layout_width="match_parent"
                    android:layout_height="46dp"
                    android:textSize="12sp"
                    android:text="Permitir panel flotante" />
            </LinearLayout>
        </ScrollView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRestore"
            style="@style/Theme.GameOptimizer.Button.Outline"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:textSize="12sp"
            android:layout_marginTop="10dp"
            android:text="Restaurar sistema" />
    </LinearLayout>

    <!-- Columna derecha: lista de juegos -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1.3"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="TUS JUEGOS"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:layout_marginBottom="8dp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvGames"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false" />
    </LinearLayout>

</LinearLayout>
