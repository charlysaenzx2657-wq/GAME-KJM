<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Comprobando estado de Shizuku..."
        android:textSize="16sp"
        android:layout_marginBottom="24dp"
        android:gravity="center" />

    <Button
        android:id="@+id/btnInstallShizuku"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Instalar Shizuku"
        android:layout_marginBottom="12dp" />

    <Button
        android:id="@+id/btnOpenDevOptions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Abrir Opciones de Desarrollador"
        android:layout_marginBottom="12dp" />

    <Button
        android:id="@+id/btnGrantPermission"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Otorgar permiso a Shizuku"
        android:layout_marginBottom="24dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Selecciona un juego para optimizar y lanzar:"
        android:textSize="14sp"
        android:layout_marginBottom="8dp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvGames"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginBottom="12dp" />

    <Button
        android:id="@+id/btnRestore"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Restaurar ajustes del sistema" />

</LinearLayout>
